# Copy to .agents/skills/read-gmail/.env (gitignored)
GMAIL_CLIENT_ID=your-google-oauth-client-id
GMAIL_CLIENT_SECRET=your-google-oauth-client-secret
GMAIL_REDIRECT_URI=http://localhost:3457/gmail/callback

# Read-only by default.
GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.readonly

# Optional; defaults store account tokens inside this skill's .data/ folder.
# GMAIL_TOKEN_DIR=/Users/sainytk/Documents/sainy-os/.agents/skills/read-gmail/.data/accounts
# GMAIL_DEFAULT_ACCOUNT_FILE=/Users/sainytk/Documents/sainy-os/.agents/skills/read-gmail/.data/default-account
