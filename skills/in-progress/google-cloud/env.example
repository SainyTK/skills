# Copy to .agents/skills/google-cloud/.env (gitignored)
# All values are optional — gcloud CLI credentials are managed separately via `gcloud auth login`.

# Pin a default project so you don't need --project on every command.
# GCLOUD_DEFAULT_PROJECT=my-project-id

# Pin a default gcloud account email (overrides gcloud's active account for all commands).
# GCLOUD_DEFAULT_ACCOUNT=you@example.com

# Override the context cache location (defaults to .agents/skills/google-cloud/.data/context.json).
# GCLOUD_CONTEXT_FILE=/custom/path/context.json
