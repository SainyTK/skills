# Copy to .agents/skills/google-office/.env (gitignored)
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3457/office/callback

# Read + write across Drive, Docs, Sheets, and Gmail. For read-only Drive/Docs/Sheets:
#   https://www.googleapis.com/auth/drive.readonly https://www.googleapis.com/auth/documents.readonly https://www.googleapis.com/auth/spreadsheets.readonly https://www.googleapis.com/auth/userinfo.email https://www.googleapis.com/auth/gmail.readonly
GOOGLE_SCOPES=https://www.googleapis.com/auth/drive https://www.googleapis.com/auth/documents https://www.googleapis.com/auth/spreadsheets https://www.googleapis.com/auth/userinfo.email https://www.googleapis.com/auth/gmail.modify

# Optional; defaults store account tokens inside this skill's .data/ folder.
# GOOGLE_TOKEN_DIR=/Users/sainytk/Documents/sainy-os/.agents/skills/google-office/.data/accounts
# GOOGLE_DEFAULT_ACCOUNT_FILE=/Users/sainytk/Documents/sainy-os/.agents/skills/google-office/.data/default-account
