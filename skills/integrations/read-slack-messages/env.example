# Copy to .agents/skills/read-slack-messages/.env (gitignored)
SLACK_CLIENT_ID=your-client-id
SLACK_CLIENT_SECRET=your-client-secret
SLACK_REDIRECT_URI=http://localhost:3456/slack/callback

# Default is user-token OAuth only. Leave bot scopes empty unless you intentionally want a bot.
SLACK_BOT_SCOPES=
SLACK_USER_SCOPES=channels:read,channels:history,groups:read,groups:history,im:read,im:history,mpim:read,mpim:history,users:read,search:read,files:read

# Optional; default stores token inside this skill's .data/ folder.
# SLACK_TOKEN_FILE=/Users/sainytk/Documents/sainy-os/.agents/skills/read-slack-messages/.data/slack-token.json
